    <!-- Client-side JavaScript -->
    <script>
      import Chart from 'chart.js/auto';

      // === DATA ===
      const treasuryByIncome = [
        { bracket: "Under $100K", pctOfClaimants: 20, pctOfDollars: 2 },
        { bracket: "$100K-$400K", pctOfClaimants: 35, pctOfDollars: 11 },
        { bracket: "$400K-$1M", pctOfClaimants: 19, pctOfDollars: 12 },
        { bracket: "Over $1M", pctOfClaimants: 26, pctOfDollars: 75 }
      ];

      const migrationGainers = [
        { state: "FL", net: 125551 },
        { state: "TX", net: 88216 },
        { state: "NC", net: 43653 },
        { state: "SC", net: 32927 },
        { state: "TN", net: 30935 }
      ];

      const migrationLosers = [
        { state: "CA", net: -144203 },
        { state: "NY", net: -108586 },
        { state: "IL", net: -45460 },
        { state: "MA", net: -26033 },
        { state: "NJ", net: -20820 }
      ];

      // === CALCULATOR ===
      type AcquisitionPeriod = 'before-2009' | '2009-2010' | '2010-2025' | 'after-july-2025';

      const stateSelect = document.getElementById('state-select') as HTMLSelectElement;
      const exitInput = document.getElementById('exit-input') as HTMLInputElement;
      const periodSelect = document.getElementById('period-select') as HTMLSelectElement;
      const resultState = document.getElementById('result-state')!;
      const resultAmount = document.getElementById('result-amount')!;
      const resultNote = document.getElementById('result-note')!;

      function formatCurrency(n: number): string {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
      }

      function parseExitAmount(raw: string): number {
        const cleaned = raw.replace(/[^0-9.]/g, '');
        const num = parseFloat(cleaned);
        return isNaN(num) ? 0 : Math.round(num);
      }

      function getExclusionRules(period: AcquisitionPeriod) {
        switch (period) {
          case 'before-2009': return { exclusionPct: 0.50, capAmount: 10_000_000 };
          case '2009-2010': return { exclusionPct: 0.75, capAmount: 10_000_000 };
          case '2010-2025': return { exclusionPct: 1.00, capAmount: 10_000_000 };
          case 'after-july-2025': return { exclusionPct: 1.00, capAmount: 15_000_000 };
        }
      }

      function calcTax(exitAmount: number, taxRate: number, conformity: string, period: AcquisitionPeriod = '2010-2025', stateCode?: string): number {
        if (conformity === 'none') return 0;
        const rules = getExclusionRules(period);
        const excludableAmount = Math.min(exitAmount, rules.capAmount);
        const exclusion = excludableAmount * rules.exclusionPct;
        const taxableGain = exitAmount - exclusion;

        if (conformity === 'conforms') return Math.round(taxableGain * (taxRate / 100));
        if (conformity === 'decoupled') return Math.round(exitAmount * (taxRate / 100));
        if (conformity === 'pending') return Math.round(exitAmount * (taxRate / 100));
        if (conformity === 'partial') {
          if (stateCode === 'HI') {
            const hawaiiExclusion = Math.min(exitAmount, rules.capAmount) * 0.50;
            return Math.round((exitAmount - hawaiiExclusion) * (taxRate / 100));
          }
          if (stateCode === 'MA') return Math.round(exitAmount * (3 / 100));
          return Math.round(exitAmount * (taxRate / 100));
        }
        return Math.round(exitAmount * (taxRate / 100));
      }

      function updateCalculator() {
        const exitAmount = parseExitAmount(exitInput.value);
        const period = periodSelect.value as AcquisitionPeriod;

        const selected = stateSelect.options[stateSelect.selectedIndex];
        const rate = parseFloat(selected.dataset.rate || '0');
        const conformity = selected.dataset.conformity || '';
        const note = selected.dataset.note || '';
        const stateName = selected.textContent?.trim() || '';
        const stateCode = selected.value;

        const tax = calcTax(exitAmount, rate, conformity, period, stateCode);
        resultState.textContent = stateName;
        resultAmount.textContent = formatCurrency(tax);
        resultAmount.className = tax > 0
          ? 'text-4xl md:text-5xl font-bold text-red-600'
          : 'text-4xl md:text-5xl font-bold text-green-600';

        let noteText = '';
        if (conformity === 'none') {
          noteText = 'No state income tax';
        } else if (conformity === 'conforms') {
          const rules = getExclusionRules(period);
          if (rules.exclusionPct < 1.0) {
            noteText = `Conforms to federal QSBS — ${Math.round(rules.exclusionPct * 100)}% exclusion (${period === 'before-2009' ? 'pre-2009' : '2009–2010'} stock). ${tax > 0 ? 'State taxes the non-excluded portion.' : ''}`;
          } else if (exitAmount > rules.capAmount) {
            noteText = `Conforms to federal QSBS — 100% exclusion up to ${formatCurrency(rules.capAmount)} cap. Amount above cap is taxed.`;
          } else {
            noteText = 'Conforms to federal QSBS — no state tax on qualified gains';
          }
        } else if (conformity === 'partial') {
          if (stateCode === 'HI') noteText = 'Hawaii allows only 50% QSBS exclusion regardless of federal rules';
          else if (stateCode === 'MA') noteText = 'Massachusetts taxes QSBS gains at a reduced 3% rate';
          else noteText = note || 'Partial conformity';
        } else if (conformity === 'pending') {
          noteText = (note || 'QSBS conformity pending') + ' — showing projected tax if enacted';
        } else if (conformity === 'decoupled') {
          noteText = note || 'Does not conform to federal QSBS — full state tax applies';
        }
        resultNote.textContent = noteText;

        // Update comparison table
        document.querySelectorAll('.comparison-row').forEach(row => {
          const el = row as HTMLElement;
          const rowRate = parseFloat(el.dataset.rate || '0');
          const rowConformity = el.dataset.conformity || '';
          const rowCode = el.dataset.code || '';
          const rowTax = calcTax(exitAmount, rowRate, rowConformity, period, rowCode);
          const taxCell = el.querySelector('.comparison-tax')!;
          taxCell.textContent = formatCurrency(rowTax);
          (taxCell as HTMLElement).className = `py-3 text-right font-semibold comparison-tax ${rowTax > 0 ? 'text-red-600' : 'text-green-600'}`;
        });

        // Update URL
        const url = new URL(window.location.href);
        url.searchParams.set('state', selected.value);
        url.searchParams.set('exit', exitAmount.toString());
        url.searchParams.set('period', period);
        window.history.replaceState({}, '', url.toString());
      }

      stateSelect.addEventListener('change', updateCalculator);
      periodSelect.addEventListener('change', updateCalculator);
      exitInput.addEventListener('input', updateCalculator);
      exitInput.addEventListener('blur', () => {
        const amount = parseExitAmount(exitInput.value);
        if (amount > 0) exitInput.value = formatCurrency(amount);
      });
      exitInput.addEventListener('focus', () => {
        const amount = parseExitAmount(exitInput.value);
        if (amount > 0) exitInput.value = amount.toString();
      });

      // Read URL params on load
      const params = new URLSearchParams(window.location.search);
      if (params.get('state')) {
        stateSelect.value = params.get('state')!;
      }
      if (params.get('exit')) {
        const exitVal = parseInt(params.get('exit')!);
        if (!isNaN(exitVal)) exitInput.value = formatCurrency(exitVal);
      }
      if (params.get('period')) {
        periodSelect.value = params.get('period')!;
      }
      updateCalculator();

      // Share button (calculator)
      document.getElementById('share-btn')?.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        const confirm = document.getElementById('share-confirm')!;
        confirm.classList.remove('hidden');
        setTimeout(() => confirm.classList.add('hidden'), 2000);
      });

      // === CTA: Copy social ===
      document.getElementById('copy-social')?.addEventListener('click', () => {
        const text = `Most startups fail. QSBS rewards the ones that don't. 75% of claimants use it exactly once — one exit, one reward. 74% earn under $1M. This isn't a loophole. It's an incentive for founders, employees, and investors who took the risk. See the data: https://qsbsfacts.org`;
        navigator.clipboard.writeText(text);
        const confirm = document.getElementById('copy-social-confirm')!;
        confirm.classList.remove('hidden');
        setTimeout(() => confirm.classList.add('hidden'), 3000);
      });

      // === CTA: Subscribe placeholder ===
      document.getElementById('subscribe-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const confirm = document.getElementById('subscribe-confirm')!;
        confirm.classList.remove('hidden');
        (e.target as HTMLFormElement).reset();
      });

      // === MOBILE MENU ===
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
      document.querySelectorAll('#mobile-menu a').forEach(a => {
        a.addEventListener('click', () => {
          document.getElementById('mobile-menu')?.classList.add('hidden');
        });
      });

      // === STATE MAP TILES ===
      document.querySelectorAll('.state-tile').forEach(tile => {
        tile.addEventListener('click', () => {
          const el = tile as HTMLElement;
          const detail = document.getElementById('state-detail')!;
          document.getElementById('detail-name')!.textContent = el.dataset.name || '';
          document.getElementById('detail-rate')!.textContent = el.dataset.rate + '%';
          const status = el.dataset.conformity || '';
          const statusEl = document.getElementById('detail-status')!;
          statusEl.textContent = status === 'none' ? 'No income tax' : status.charAt(0).toUpperCase() + status.slice(1);
          document.getElementById('detail-note')!.textContent = el.dataset.note || 'Standard federal conformity.';
          detail.classList.remove('hidden');
        });
      });

      // === CHARTS ===
      Chart.defaults.font.family = "'Inter', system-ui, sans-serif";

      // Claimants chart (4 buckets, by unique claimants)
      // Custom plugin to render data labels on bars
      const barLabelPlugin = {
        id: 'barLabels',
        afterDatasetsDraw(chart: any) {
          const { ctx } = chart;
          chart.data.datasets.forEach((dataset: any, datasetIndex: number) => {
            const meta = chart.getDatasetMeta(datasetIndex);
            meta.data.forEach((bar: any, index: number) => {
              const value = dataset.data[index];
              ctx.save();
              ctx.fillStyle = '#1e3a5f';
              ctx.font = 'bold 14px Inter, system-ui, sans-serif';
              ctx.textAlign = 'center';
              ctx.textBaseline = 'bottom';
              ctx.fillText(value + '%', bar.x, bar.y - 6);
              ctx.restore();
            });
          });
        }
      };

      new Chart(document.getElementById('claimants-chart') as HTMLCanvasElement, {
        type: 'bar',
        data: {
          labels: treasuryByIncome.map(d => d.bracket),
          datasets: [{
            label: '% of claimants',
            data: treasuryByIncome.map(d => d.pctOfClaimants),
            backgroundColor: ['#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe'],
            borderRadius: 6,
          }]
        },
        plugins: [barLabelPlugin],
        options: {
          responsive: true,
          layout: { padding: { top: 24 } },
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx) => ctx.parsed.y + '% of claimants' } }
          },
          scales: {
            y: { beginAtZero: true, max: 50, ticks: { callback: (v) => v + '%' } },
            x: { grid: { display: false } }
          }
        }
      });

      // Distribution chart (4 percentiles)
      new Chart(document.getElementById('distribution-chart') as HTMLCanvasElement, {
        type: 'bar',
        data: {
          labels: ['25th percentile', '50th (median)', '75th percentile', '90th percentile'],
          datasets: [{
            label: 'Annual exclusion',
            data: [30, 2810, 67820, 590940],
            backgroundColor: ['#93c5fd', '#60a5fa', '#3b82f6', '#1d4ed8'],
            borderRadius: 6,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx) => '$' + ctx.parsed.x.toLocaleString() } }
          },
          scales: {
            x: {
              beginAtZero: true,
              ticks: { callback: (v) => '$' + Number(v).toLocaleString() }
            },
            y: { grid: { display: false } }
          }
        }
      });

      // Migration gainers
      new Chart(document.getElementById('gainers-chart') as HTMLCanvasElement, {
        type: 'bar',
        data: {
          labels: migrationGainers.map(d => d.state),
          datasets: [{
            label: 'Net filers gained',
            data: migrationGainers.map(d => d.net),
            backgroundColor: '#16a34a',
            borderRadius: 6,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx) => '+' + ctx.parsed.x.toLocaleString() + ' filers' } }
          },
          scales: {
            x: { beginAtZero: true, ticks: { callback: (v) => '+' + Number(v).toLocaleString() } },
            y: { grid: { display: false } }
          }
        }
      });

      // Migration losers
      new Chart(document.getElementById('losers-chart') as HTMLCanvasElement, {
        type: 'bar',
        data: {
          labels: migrationLosers.map(d => d.state),
          datasets: [{
            label: 'Net filers lost',
            data: migrationLosers.map(d => d.net),
            backgroundColor: '#dc2626',
            borderRadius: 6,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx) => ctx.parsed.x.toLocaleString() + ' filers' } }
          },
          scales: {
            x: { ticks: { callback: (v) => Number(v).toLocaleString() } },
            y: { grid: { display: false } }
          }
        }
      });
    </script>

