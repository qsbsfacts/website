---
import '../styles/global.css';
import statesData from '../../data/states.json';
import treasuryData from '../../data/treasury-summary.json';
import migrationData from '../../data/migration.json';

const comparisonStates = ['TX', 'FL', 'WA', 'CA', 'OR', 'NY'];
const comparisonData = comparisonStates.map(code => statesData.find(s => s.code === code)!);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Most startups fail. QSBS rewards the founders who built them, the employees who joined early, and the investors who backed them. Here's what the data actually shows." />
    <link rel="canonical" href="https://qsbsfacts.org" />
    <meta property="og:title" content="QSBS Facts — Most startups fail. QSBS rewards the ones that don't." />
    <meta property="og:description" content="75% of QSBS claimants use it exactly once. Data-driven analysis of Section 1202 tax policy." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://qsbsfacts.org" />
    <meta property="og:site_name" content="QSBS Facts" />
    <meta property="og:image" content="https://qsbsfacts.org/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="QSBS Facts — Most startups fail. QSBS rewards the ones that don't." />
    <meta name="twitter:description" content="75% of QSBS claimants use it exactly once. Data-driven analysis of Section 1202 tax policy." />
    <meta name="twitter:image" content="https://qsbsfacts.org/og-image.png" />
    <title>QSBS Facts — Most startups fail. QSBS rewards the ones that don't.</title>
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "QSBS Facts",
        "url": "https://qsbsfacts.org",
        "description": "Data-driven analysis of Section 1202 Qualified Small Business Stock (QSBS) tax policy."
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "QSBS Facts",
        "url": "https://qsbsfacts.org",
        "description": "Data-driven advocacy for Section 1202 QSBS tax policy based on U.S. Treasury data, academic studies, and migration statistics."
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "QSBS Facts — Most startups fail. QSBS rewards the ones that don't.",
        "url": "https://qsbsfacts.org",
        "description": "75% of QSBS claimants use it exactly once. Data-driven analysis of Section 1202 tax policy.",
        "datePublished": "2025-03-20",
        "dateModified": "2026-03-25",
        "citation": [
          {
            "@type": "CreativeWork",
            "name": "U.S. Treasury OTA Working Paper 127",
            "url": "https://home.treasury.gov/system/files/131/WP-127.pdf",
            "datePublished": "2025-01"
          },
          {
            "@type": "ScholarlyArticle",
            "name": "Edwards & Todenhaupt (2020)",
            "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=3520783"
          },
          {
            "@type": "ScholarlyArticle",
            "name": "Chen & Farre-Mensa (2023/2025)",
            "url": "https://ssrn.com/abstract=4482626"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is QSBS (Qualified Small Business Stock)?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "QSBS refers to stock in a qualified small business under IRC Section 1202. If you hold QSBS for at least 5 years, you can exclude up to $10 million (or 10x your basis) in capital gains from federal taxes. The exclusion was created in 1993 under President Clinton and expanded to 100% under President Obama in 2010. It incentivizes investment in early-stage companies by reducing the tax penalty on successful outcomes."
            }
          },
          {
            "@type": "Question",
            "name": "Is it true that 94% of QSBS benefits go to millionaires?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "This claim from ITEP is misleading. It's a dollar-weighted statistic, not a count of people. Treasury data (OTA WP-127) shows 74% of QSBS claimants earn under $1 million by average income excluding QSBS gains. ITEP arrives at 94% by adding two groups: 74% of dollars going to people already over $1M, plus 20% going to people earning under $1M whose one-time startup exit temporarily pushed them over. The second group — founders and employees with a single successful exit — is exactly who QSBS was designed for."
            }
          },
          {
            "@type": "Question",
            "name": "Who actually uses QSBS?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "According to U.S. Treasury data (2012–2022): 75% of individuals claimed QSBS in only a single year — one exit, one reward. The median annual exclusion is just $2,810. The 75th percentile is $67,820. The largest claimant group (35%) earns $100K–$400K. These are founders, early employees, and seed investors — not repeat tax avoiders."
            }
          },
          {
            "@type": "Question",
            "name": "Does the QSBS incentive actually work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Two peer-reviewed studies provide evidence: Edwards & Todenhaupt (2020) found startup investment increased approximately 12% after the 100% exclusion was enacted in 2010. Chen & Farre-Mensa (2023/2025) found that QSBS-eligible industries experienced more firm births, more startup employment, and increased first-round venture capital compared to ineligible industries."
            }
          },
          {
            "@type": "Question",
            "name": "What happens when states decouple from QSBS?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "States that decouple from federal QSBS conformity tax startup exits that would otherwise be excluded. IRS migration data (2021–2022) shows decoupled high-tax states like California (-144,203 net filers) and New York (-108,586) are losing residents to conforming, lower-tax states like Florida (+125,551) and Texas (+88,216). California lost $102 billion in AGI to outmigration from 2020–2022. The pattern suggests decoupling drives founders and capital to conforming states, losing both the people and the revenue."
            }
          }
        ]
      }
    ]
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-primary-950/95 backdrop-blur-sm border-b border-primary-800">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="#" class="text-white font-bold text-lg">QSBS Facts</a>
        <div class="hidden md:flex items-center gap-6 text-sm text-primary-200">
          <a href="#evidence" class="hover:text-white transition-colors">Evidence</a>
          <a href="#who-uses-it" class="hover:text-white transition-colors">Who Uses It</a>
          <a href="#claim-vs-reality" class="hover:text-white transition-colors">The 94% Claim</a>
          <a href="#calculator" class="hover:text-white transition-colors">Calculator</a>
