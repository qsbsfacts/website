---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogTitle?: string;
  ogDescription?: string;
  jsonLd?: object[];
}

const {
  title,
  description,
  canonicalPath = '',
  ogTitle,
  ogDescription,
  jsonLd = [],
} = Astro.props;

const siteUrl = 'https://qsbsfacts.org';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="QSBS Facts" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <title>{title}</title>
    {jsonLd.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-primary-950/95 backdrop-blur-sm border-b border-primary-800">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-white font-bold text-lg">QSBS Facts</a>
        <div class="hidden md:flex items-center gap-6 text-sm text-primary-200">
          <a href="/evidence" class="hover:text-white transition-colors">Evidence</a>
          <a href="/who-uses-it" class="hover:text-white transition-colors">Who Uses It</a>
          <a href="/the-94-percent-claim" class="hover:text-white transition-colors">The 94% Claim</a>
          <a href="/calculator" class="hover:text-white transition-colors">Calculator</a>
          <a href="/state-impact" class="hover:text-white transition-colors">Migration</a>
          <a href="/sources" class="hover:text-white transition-colors">Sources</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-white" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden bg-primary-950 border-t border-primary-800 px-4 py-3">
        <div class="flex flex-col gap-3 text-sm text-primary-200">
          <a href="/evidence" class="hover:text-white">Evidence</a>
          <a href="/who-uses-it" class="hover:text-white">Who Uses It</a>
          <a href="/the-94-percent-claim" class="hover:text-white">The 94% Claim</a>
          <a href="/calculator" class="hover:text-white">Calculator</a>
          <a href="/state-impact" class="hover:text-white">Migration</a>
          <a href="/sources" class="hover:text-white">Sources</a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="bg-primary-950 text-primary-300 px-4 py-12">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-white font-bold text-lg mb-2">QSBS Facts</p>
        <p class="text-sm mb-4">Data-driven analysis of Section 1202 QSBS tax policy.</p>
        <div class="flex flex-wrap justify-center gap-4 text-xs text-primary-400 mb-4">
          <a href="/evidence" class="hover:text-white">Evidence</a>
          <a href="/who-uses-it" class="hover:text-white">Who Uses It</a>
          <a href="/the-94-percent-claim" class="hover:text-white">The 94% Claim</a>
          <a href="/calculator" class="hover:text-white">Calculator</a>
          <a href="/state-impact" class="hover:text-white">State Impact</a>
          <a href="/sources" class="hover:text-white">Sources</a>
        </div>
        <p class="text-xs text-primary-500">
          All data sourced from U.S. Treasury, IRS, and peer-reviewed academic research.
          This site presents factual analysis and is not tax advice.
        </p>
        <p class="text-xs text-primary-600 mt-2">Updated March 2026.</p>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
      document.querySelectorAll('#mobile-menu a').forEach(a => {
        a.addEventListener('click', () => {
          document.getElementById('mobile-menu')?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
